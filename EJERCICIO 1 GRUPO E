#include <iostream>
using namespace std;

int main() {
    int matriz[2][2];
    int suma = 0;

    // 1. Ingresar valores en la matriz
    cout << "Ingrese valores para la matriz 2x2:\n";
    for (int i = 0; i < 2; i++) {
        for (int j = 0; j < 2; j++) {
            cout << "Elemento [" << i << "][" << j << "]: ";
            cin >> matriz[i][j];
            suma += matriz[i][j]; // acumular suma
        }
    }

    // 2. Mostrar la matriz
    cout << "\nMatriz ingresada:\n";
    for (int i = 0; i < 2; i++) {
        for (int j = 0; j < 2; j++) {
            cout << matriz[i][j] << " ";
        }
        cout << endl;
    }

    // 3. Mostrar la suma total
    cout << "\nSuma total de elementos: " << suma << endl;

    return 0;
}
